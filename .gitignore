# --------------------------------------------------
# Open Agentic CMO — gitignore
# --------------------------------------------------

# Environment files
.env
.env.local
.env.development
.env.production
.env.test

# Secrets and credentials
*.pem
*.key
*.crt
*.p12
*.pfx
secrets.json
credentials.json
service-account.json
google-credentials.json

# Node / JavaScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Build / cache
dist/
build/
.cache/
.tmp/
temp/
tmp/

# Local runtime data
.paperclip/
.local/
.runtime/

# Backups
*.bak
*.backup
*.old
