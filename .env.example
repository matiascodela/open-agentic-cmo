# Open Agentic CMO environment variables
# Copy this file to .env and replace placeholder values with your own credentials.
# Never commit real API keys, tokens, database IDs, or private URLs.

# --------------------------------------------------
# Notion
# --------------------------------------------------

NOTION_API_KEY=your_notion_api_key_here
NOTION_CONTENT_DATABASE_ID=your_notion_content_database_id_here
NOTION_RESEARCH_DATABASE_ID=your_notion_research_database_id_here

# --------------------------------------------------
# Telegram
# --------------------------------------------------

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
