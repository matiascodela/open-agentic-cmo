{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/piggywallet/open-agentic-cmo/schemas/signal.schema.json",
  "title": "Open Agentic CMO Signal",
  "description": "Canonical schema for workflow transition signals in Open Agentic CMO. Signals must be posted on the parent workflow issue to count as final workflow evidence. Subtask copies are allowed for traceability, but subtask-only signals are not enough for final completion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "producer",
    "issue",
    "status",
    "artifact",
    "timestamp"
  ],
  "properties": {
    "type": {
      "type": "string",
      "description": "The signal type used to mark workflow state transitions.",
      "enum": [
        "AUDIT_READY",
        "SYNTHESIS_READY",
        "CONTENT_SET_READY",
        "NOTION_SYNC_COMPLETE",
        "DELIVERY_COMPLETE",
        "BLOCKED",
        "RETRY_REQUIRED",
        "TIMEOUT_DETECTED",
        "RECOVERY_IN_PROGRESS",
        "RECOVERY_COMPLETE"
      ]
    },
    "producer": {
      "type": "string",
      "description": "The agent that produced the signal.",
      "enum": [
        "Porky",
        "Babe",
        "Hamm",
        "Pumba"
      ]
    },
    "issue": {
      "type": "string",
      "description": "The parent workflow issue ID. This is the canonical workflow record and source of truth.",
      "minLength": 1,
      "examples": [
        "PIG-101"
      ]
    },
    "subtask_issue": {
      "type": "string",
      "description": "The subtask issue ID that produced the signal, when available. For Porky-owned parent-phase signals, this may match the parent issue or be omitted depending on runtime behavior.",
      "minLength": 1,
      "examples": [
        "PIG-103"
      ]
    },
    "status": {
      "type": "string",
      "description": "The completion or failure state represented by the signal. Completion signals must use COMPLETE. Blocked, timeout, and recovery failure signals must use FAILED unless recovery has completed successfully.",
      "enum": [
        "COMPLETE",
        "FAILED"
      ]
    },
    "artifact": {
      "type": "string",
      "description": "The artifact or workflow area associated with the signal.",
      "enum": [
        "audit",
        "strategy",
        "content_set",
        "notion_content_pipeline",
        "telegram_delivery",
        "workflow",
        "content_generation",
        "persistence_or_delivery"
      ]
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp for when the signal was emitted.",
      "format": "date-time",
      "examples": [
        "2026-05-01T14:20:00Z"
      ]
    },
    "notes": {
      "type": "string",
      "description": "Optional short human-readable context for blocked, timeout, or recovery signals. Do not use notes as a substitute for the required artifact.",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "AUDIT_READY"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "producer": {
            "const": "Babe"
          },
          "status": {
            "const": "COMPLETE"
          },
          "artifact": {
            "const": "audit"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "SYNTHESIS_READY"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "producer": {
            "const": "Porky"
          },
          "status": {
            "const": "COMPLETE"
          },
          "artifact": {
            "const": "strategy"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "CONTENT_SET_READY"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "producer": {
            "const": "Hamm"
          },
          "status": {
            "const": "COMPLETE"
          },
          "artifact": {
            "const": "content_set"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "NOTION_SYNC_COMPLETE"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "producer": {
            "const": "Pumba"
          },
          "status": {
            "const": "COMPLETE"
          },
          "artifact": {
            "const": "notion_content_pipeline"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "DELIVERY_COMPLETE"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "producer": {
            "const": "Pumba"
          },
          "status": {
            "const": "COMPLETE"
          },
          "artifact": {
            "const": "telegram_delivery"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "BLOCKED"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "status": {
            "const": "FAILED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "TIMEOUT_DETECTED"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "producer": {
            "const": "Porky"
          },
          "status": {
            "const": "FAILED"
          },
          "artifact": {
            "const": "workflow"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "RECOVERY_IN_PROGRESS"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "producer": {
            "const": "Porky"
          },
          "status": {
            "const": "FAILED"
          },
          "artifact": {
            "const": "workflow"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "RECOVERY_COMPLETE"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "producer": {
            "const": "Porky"
          },
          "status": {
            "const": "COMPLETE"
          },
          "artifact": {
            "const": "workflow"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "RETRY_REQUIRED"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "producer": {
            "const": "Porky"
          },
          "status": {
            "const": "FAILED"
          },
          "artifact": {
            "const": "workflow"
          }
        }
      }
    }
  ],
  "examples": [
    {
      "type": "AUDIT_READY",
      "producer": "Babe",
      "issue": "PIG-101",
      "subtask_issue": "PIG-102",
      "status": "COMPLETE",
      "artifact": "audit",
      "timestamp": "2026-05-01T14:01:00Z"
    },
    {
      "type": "SYNTHESIS_READY",
      "producer": "Porky",
      "issue": "PIG-101",
      "subtask_issue": "PIG-101",
      "status": "COMPLETE",
      "artifact": "strategy",
      "timestamp": "2026-05-01T14:10:00Z"
    },
    {
      "type": "CONTENT_SET_READY",
      "producer": "Hamm",
      "issue": "PIG-101",
      "subtask_issue": "PIG-103",
      "status": "COMPLETE",
      "artifact": "content_set",
      "timestamp": "2026-05-01T14:20:00Z"
    },
    {
      "type": "NOTION_SYNC_COMPLETE",
      "producer": "Pumba",
      "issue": "PIG-101",
      "subtask_issue": "PIG-104",
      "status": "COMPLETE",
      "artifact": "notion_content_pipeline",
      "timestamp": "2026-05-01T14:35:00Z"
    },
    {
      "type": "DELIVERY_COMPLETE",
      "producer": "Pumba",
      "issue": "PIG-101",
      "subtask_issue": "PIG-104",
      "status": "COMPLETE",
      "artifact": "telegram_delivery",
      "timestamp": "2026-05-01T14:40:00Z"
    },
    {
      "type": "BLOCKED",
      "producer": "Hamm",
      "issue": "PIG-101",
      "subtask_issue": "PIG-103",
      "status": "FAILED",
      "artifact": "content_generation",
      "timestamp": "2026-05-01T14:30:00Z",
      "notes": "Hamm is blocked because no valid strategy artifact exists."
    },
    {
      "type": "BLOCKED",
      "producer": "Porky",
      "issue": "PIG-101",
      "subtask_issue": "PIG-101",
      "status": "FAILED",
      "artifact": "workflow",
      "timestamp": "2026-05-01T14:45:00Z",
      "notes": "Porky blocked the workflow because CONTENT_SET_READY exists but the full content_set artifact is missing."
    },
    {
      "type": "TIMEOUT_DETECTED",
      "producer": "Porky",
      "issue": "PIG-101",
      "subtask_issue": "PIG-101",
      "status": "FAILED",
      "artifact": "workflow",
      "timestamp": "2026-05-01T15:00:00Z",
      "notes": "Porky timed out waiting for CONTENT_SET_READY."
    },
    {
      "type": "RECOVERY_COMPLETE",
      "producer": "Porky",
      "issue": "PIG-101",
      "subtask_issue": "PIG-101",
      "status": "COMPLETE",
      "artifact": "workflow",
      "timestamp": "2026-05-01T15:10:00Z",
      "notes": "Recovery completed after Hamm published the missing content_set artifact."
    }
  ],
  "$comment": "Workflow-level constraints not fully expressible in JSON Schema: completion signals must be backed by valid artifacts posted on the parent issue; AUDIT_READY requires an audit artifact with critical_flags; SYNTHESIS_READY requires excluded_claims and safe_framing when audit risks affect publishing; CONTENT_SET_READY requires content to avoid excluded_claims; NOTION_SYNC_COMPLETE requires both Content Pipeline and Research Babe persistence; DELIVERY_COMPLETE requires telegram_delivery verification. Pumba should not emit BLOCKED for harmless early wake-ups before Porky explicitly delegates the Notion + Delivery phase."
}
